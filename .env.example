# Hero Echoes online service (game client)
# Copy to .env and edit values for local ranked mode:
#   cp .env.example .env

# Dev / debug (desktop run, Android debug APK). Localhost is rewritten to
# 10.0.2.2 for the Android emulator. Desktop falls back to project-links.properties
# backend.url when ECHO_BACKEND_URL is unset (packaged runs without a .env).
ECHO_BACKEND_URL=http://localhost:3000
ECHO_API_KEY=change-me-to-match-backend-echo-api-key

# Android release APK/AAB only (baked into BuildConfig at assemble time).
# Optional ECHO_BACKEND_URL_RELEASE override — if unset, release uses backend.url
# from services/src/main/resources/project-links.properties (then ECHO_BACKEND_URL).
# Do not commit real keys.
ECHO_API_KEY_RELEASE=change-me-for-release
