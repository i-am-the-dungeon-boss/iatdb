# Hero Echoes online service (game client)
# Copy to .env and edit values for local ranked mode:
#   cp .env.example .env

ECHO_BACKEND_URL=http://localhost:3000
ECHO_API_KEY=change-me-to-match-backend-echo-api-key

# Android release APK/AAB (baked into BuildConfig at assemble time).
# Falls back to ECHO_BACKEND_URL / ECHO_API_KEY if unset.
# Debug Android builds use ECHO_BACKEND_URL and rewrite localhost/127.0.0.1 → 10.0.2.2 (emulator).
ECHO_BACKEND_URL_RELEASE=https://your-production-host
ECHO_API_KEY_RELEASE=change-me-for-release
